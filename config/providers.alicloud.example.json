{
  "schemaVersion": 1,
  "defaultProvider": "alicloud-acs",
  "providers": {
    "alicloud-acs": {
      "displayName": "Alibaba Cloud ACS Agent Sandbox",
      "protocol": "e2b-compatible",
      "api": {
        "baseUrl": "http://sandbox-manager.sandbox-system.svc.cluster.local:7788",
        "privateNetworkOnly": true,
        "apiKeyEnv": "ALICLOUD_ACS_E2B_API_KEY",
        "compatibilityVersion": "e2b-python-2.24-private-protocol",
        "requestTimeoutMs": 30000
      },
      "sandbox": {
        "templateId": "onyxclaw",
        "timeoutMs": 300000,
        "onTimeout": "kill",
        "secure": false,
        "defaultUser": "node",
        "homeDir": "/home/node",
        "workspaceDir": "/home/node/.openclaw/workspace"
      },
      "openclaw": {
        "binary": "node /app/openclaw.mjs",
        "gatewayPort": 18789,
        "installMode": "preinstalled",
        "pluginInstallMode": "preinstalled"
      },
      "channel": {
        "publicUrl": "ws://onyxclaw-channel.default.svc.cluster.local:8080/internal/channel/connect",
        "privateNetworkOnly": true,
        "connectTimeoutMs": 120000,
        "signingSecretEnv": "ALICLOUD_ACS_CHANNEL_SIGNING_SECRET"
      },
      "model": {
        "provider": "openai-compatible",
        "model": "replace-with-cloud-test-model",
        "apiKeyEnv": "ALICLOUD_ACS_MODEL_API_KEY"
      },
      "cleanupPolicy": "kill",
      "capabilities": {
        "pauseResume": true,
        "memoryPersistence": true,
        "publicEgress": true,
        "vpc": true
      }
    }
  }
}
