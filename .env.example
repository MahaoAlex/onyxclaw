# Select a trusted profile from the provider configuration file.
ONYXCLAW_PROVIDER=vendor-a
ONYXCLAW_PROVIDER_CONFIG=config/providers.local.json

# Secret values referenced by config/providers.example.json.
VENDOR_A_E2B_API_KEY=
VENDOR_A_MODEL_API_KEY=
VENDOR_A_CHANNEL_SIGNING_SECRET=

# Deployment-wide optional configuration.
ARTIFACT_STORE_URL=
# Alibaba Cloud ACS IaC (secrets are examples only; never commit real values)
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIBABA_CLOUD_REGION=cn-hangzhou
TF_VAR_e2b_domain=sandbox.example.com
TF_VAR_sandbox_admin_api_key=
ONYXCLAW_OPENCLAW_IMAGE=
ONYXCLAW_ACS_ACCOUNT_READY=false
ONYXCLAW_WARM_POOL_REPLICAS=2
