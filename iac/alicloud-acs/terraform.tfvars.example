region                        = "cn-hangzhou"
name_prefix                   = "onyxclaw-acs-dev"
e2b_domain                    = "sandbox.example.com"
sandbox_manager_ingress_class = "alb"
sandbox_manager_tls           = false
create_default_alb             = false

# Pass the secret through TF_VAR_sandbox_admin_api_key. Do not put it here.
# The default creates public egress and a public API Server so a macOS laptop
# can run kubectl. Set both flags to false when the runner is inside the VPC.
enable_snat              = true
enable_public_api_server = true
deletion_protection      = false
