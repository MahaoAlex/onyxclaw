{
  "agents": {
    "defaults": {
      "model": {
        "primary": "acs-model/example-chat"
      },
      "workspace": "/home/node/.openclaw/workspace"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "acs-model": {
        "baseUrl": "https://model-api.example.com/v1",
        "apiKey": "example-model-api-key-injected-at-runtime",
        "api": "openai-completions",
        "models": [
          {
            "id": "example-chat",
            "name": "Example Chat Model"
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "example-gateway-token-replace-before-deploy"
    }
  },
  "plugins": {
    "load": {
      "paths": [
        "/opt/onyxclaw/channel"
      ]
    },
    "entries": {
      "onyxclaw": {
        "enabled": true
      }
    }
  },
  "channels": {
    "onyxclaw": {
      "enabled": true,
      "platformUrl": "ws://onyxclaw-app.default.svc.cluster.local:18890",
      "instanceId": "example-runtime-instance-id",
      "bootstrapToken": "example-one-time-bootstrap-token"
    }
  }
}
