{
  "agents": {
    "defaults": {
      "model": {
        "primary": "acs-model/example-chat"
      },
      "workspace": "/home/node/.openclaw/workspace"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "acs-model": {
        "baseUrl": "https://model-api.example.com/v1",
        "apiKey": "__ONYXCLAW_MODEL_API_KEY__",
        "api": "openai-completions",
        "models": [
          {
            "id": "example-chat",
            "name": "Example Chat Model"
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "example-gateway-token-replace-before-deploy"
    }
  },
  "plugins": {
    "load": {
      "paths": []
    },
    "entries": {}
  },
  "channels": {}
}
